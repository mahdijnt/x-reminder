# ---- Shared ----
ENVIRONMENT=development
LOG_LEVEL=INFO

# ---- Backend ----
APP_NAME=x-reminder-api
APP_VERSION=0.1.0
DEBUG=false
API_V1_PREFIX=/api/v1
SECRET_KEY=replace-with-strong-secret
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=["GET","POST","PUT","PATCH","DELETE","OPTIONS"]
CORS_ALLOW_HEADERS=["Authorization","Content-Type","X-Request-ID"]
REDIS_ENABLED=true
REDIS_URL=redis://localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_SSL=false
REDIS_KEY_PREFIX=xreminder
REDIS_MAX_CONNECTIONS=10
REDIS_TTL_SESSION=86400
REDIS_TTL_CACHE=300
REDIS_TTL_TEMP=300
REDIS_TTL_SCHEDULER_LOCK=60
QDRANT_ENABLED=false
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
X_CLIENT_ID=
X_CLIENT_SECRET=
X_BEARER_TOKEN=
X_API_KEY=
X_API_SECRET=
X_CALLBACK_URL=http://localhost:8000/api/v1/x/oauth/callback
X_API_BASE_URL=https://api.twitter.com
X_OAUTH_AUTHORIZE_URL=https://twitter.com/i/oauth2/authorize
X_OAUTH_TOKEN_URL=https://api.twitter.com/2/oauth2/token
X_OAUTH_REVOKE_URL=https://api.twitter.com/2/oauth2/revoke
TELEGRAM_BOT_TOKEN=
TELEGRAM_API_BASE_URL=https://api.telegram.org
TELEGRAM_HTTP_TIMEOUT=30
ERROR_MONITORING_PROVIDER=none
ERROR_MONITORING_DSN=

# ---- Dashboard ----
NEXT_PUBLIC_APP_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_USE_MOCK_API=true
NEXT_PUBLIC_SENTRY_DSN=

# ---- Telegram bot ----
BOT_LOG_LEVEL=INFO
DEFAULT_LOCALE=en
USE_MOCK_BACKEND=true
BOT_BACKEND_BASE_URL=http://localhost:8000/api/v1
BOT_API_TIMEOUT_SECONDS=10
BOT_ERROR_MONITORING_PROVIDER=none
BOT_ERROR_MONITORING_DSN=


