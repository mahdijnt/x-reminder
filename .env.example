# Copy this file to `.env` and fill in real values
REDIS_URL=redis://localhost:6379/0
REDIS_ENABLED=true
REDIS_KEY_PREFIX=xreminder
REDIS_MAX_CONNECTIONS=10
REDIS_SOCKET_TIMEOUT=5.0
REDIS_SOCKET_CONNECT_TIMEOUT=5.0
REDIS_HEALTH_CHECK_INTERVAL=30
REDIS_RETRY_MAX_ATTEMPTS=3
REDIS_RETRY_BASE_DELAY=0.5
REDIS_RETRY_MAX_DELAY=10.0
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=REPLACE_ME

QDRANT_ENABLED=false
QDRANT_COLLECTION_TWEETS=tweets
QDRANT_COLLECTION_ACCOUNTS=accounts
QDRANT_COLLECTION_CONVERSATIONS=conversations
QDRANT_VECTOR_SIZE=384
QDRANT_TIMEOUT_SECONDS=30
QDRANT_RETRY_MAX_ATTEMPTS=3

X_CLIENT_ID=REPLACE_ME
X_CLIENT_SECRET=REPLACE_ME
X_BEARER_TOKEN=REPLACE_ME
X_API_KEY=REPLACE_ME
X_API_SECRET=REPLACE_ME
X_CALLBACK_URL=http://localhost:8000/api/v1/x/oauth/callback
X_API_BASE_URL=https://api.twitter.com
X_OAUTH_SCOPES=tweet.read,users.read,follows.read,offline.access
X_HTTP_TIMEOUT=30
X_RETRY_MAX_ATTEMPTS=3
X_RETRY_BASE_DELAY=1.0
X_RETRY_MAX_DELAY=30.0
X_SYNC_SCHEDULER_ENABLED=false
X_SYNC_INTERVAL_MINUTES=30
X_SYNC_APP_USER_IDS=

TELEGRAM_BOT_TOKEN=REPLACE_ME
# --- Telegram bot ---
BOT_LOG_LEVEL=INFO
DEFAULT_LOCALE=en
USE_MOCK_BACKEND=true


SECRET_KEY=REPLACE_ME
JWT_SECRET=REPLACE_ME

# --- Backend (FastAPI) ---
APP_NAME=x-reminder-api
APP_VERSION=0.1.0
ENVIRONMENT=development
DEBUG=true
API_V1_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
LOG_LEVEL=INFO
LOG_JSON=false
RATE_LIMIT_ENABLED=false
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

MONITORING_ENABLED=true
MONITORING_WORKER_ENABLED=true
MONITORING_SIX_HOUR_INTERVAL_MINUTES=360
MONITORING_REALTIME_INTERVAL_SECONDS=120
MONITORING_QUEUE_NAME=monitoring:jobs
MONITORING_RETRY_MAX_ATTEMPTS=5
MONITORING_RETRY_BASE_DELAY_SECONDS=30
MONITORING_JOB_HISTORY_TTL_SECONDS=604800
MONITORING_WORKER_CONCURRENCY=2
MONITORING_SHUTDOWN_TIMEOUT_SECONDS=30
MONITORING_POLL_BATCH_SIZE=50
MONITORING_APP_USER_IDS=

NOTIFICATIONS_ENABLED=true
NOTIFICATIONS_WORKER_ENABLED=true
NOTIFICATIONS_QUEUE_NAME=notifications:jobs
NOTIFICATIONS_RETRY_MAX_ATTEMPTS=5
NOTIFICATIONS_RETRY_BASE_DELAY_SECONDS=60
NOTIFICATIONS_FAILURE_QUEUE_TTL_SECONDS=2592000
NOTIFICATIONS_HISTORY_TTL_SECONDS=604800
NOTIFICATIONS_BATCH_WINDOW_SECONDS=30
NOTIFICATIONS_BATCH_MAX_SIZE=5
NOTIFICATIONS_WORKER_CONCURRENCY=2
NOTIFICATIONS_TELEGRAM_RATE_PER_CHAT=1.0
NOTIFICATIONS_TELEGRAM_RATE_GLOBAL=25.0
TELEGRAM_BOT_TOKEN=

ANALYTICS_ENABLED=true
ANALYTICS_EXPORT_MAX_POINTS=120
ANALYTICS_TOP_ACCOUNTS_LIMIT=8
