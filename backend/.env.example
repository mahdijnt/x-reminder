# Backend environment (copy to .env and set real values)
ENVIRONMENT=development
LOG_LEVEL=INFO
APP_NAME=x-reminder-api
APP_VERSION=0.1.0
DEBUG=false
API_V1_PREFIX=/api/v1
SECRET_KEY=replace-with-strong-secret
JWT_SECRET=replace-with-strong-jwt-secret
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000","https://x-reminder.vercel.app"]
CORS_ALLOW_CREDENTIALS=true
DATABASE_URL=
REDIS_ENABLED=true
REDIS_URL=redis://localhost:6379/0
REDIS_SSL=false
REDIS_KEY_PREFIX=xreminder
QDRANT_ENABLED=false
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
X_CLIENT_ID=
X_CLIENT_SECRET=
X_BEARER_TOKEN=
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=
X_CALLBACK_URL=http://localhost:3000/api/auth/x/callback
X_TOKEN_ENCRYPTION_KEY=
X_SYNC_SCHEDULER_ENABLED=false
MONITORING_ENABLED=false
NOTIFICATIONS_ENABLED=false
TELEGRAM_BOT_TOKEN=
ERROR_MONITORING_PROVIDER=none
ERROR_MONITORING_DSN=
